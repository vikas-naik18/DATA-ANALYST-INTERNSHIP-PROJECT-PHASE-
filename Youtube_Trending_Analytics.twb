      <column caption='AVG VIEWS' datatype='real' name='[Calculation_0862334186442752]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([views])' />
      </column>
      <column caption='Count of Video Id' datatype='integer' name='[Calculation_0862334187724802]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='count([video_id])' />
      </column>
      <column caption='SUM OF VIEWS' datatype='integer' name='[Calculation_0862334188122115]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([views])' />
      </column>
      <column caption='Engagement Rate' datatype='real' name='[Calculation_0862334189228036]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([likes]+[comment_count])/[views]' />
      </column>
      <column caption='AVG Engagement Rate' datatype='real' name='[Calculation_0862334189715461]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG(([likes]+[comment_count])/[views])' />
      </column>
      <column caption='AVG Trending Duration' datatype='real' name='[Calculation_0862334190444550]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([trending_duration])' />
      </column>
      <column aggregation='Sum' caption='Publish Hour Fixed' datatype='integer' name='[Calculation_0862334196690954]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEPART(&apos;hour&apos;, DATETIME([publish_date]))' />
      </column>
      <column caption='Publish Month' datatype='string' name='[Calculation_0862334197387275]' role='dimension' type='nominal'>
